#include <stdio.h>
#include <stdlib.h>
#define MAX 100

int adj[MAX][MAX];
int visited[MAX];
int queue[MAX];

int bfs(int n, int start, int end){
    int front = 0, rear = 0;
    int distance[MAX];

    for(int i = 1; i <= n; i++) {
        visited[i] = 0;
        distance[i] = -1;
    }

    visited[start] = 1;
    distance[start] = 0;
    queue[rear++] = start;

    while(front < rear) {
        int current = queue[front++];

        for(int i = 1; i <= n; i++) {
            if(adj[current][i] == 1 && !visited[i]){
                visited[i] = 1;
                distance[i] = distance[current] + 1;
                queue[rear++] = i;

                if(i == end)
                    return distance[i];
            }
        }
    }

    return -1;
}

int main(){
    int n, m;
    scanf("%d %d", &n, &m);

    for(int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        adj[v][u] = 1;
    }

    int start, end;
    scanf("%d %d", &start, &end);

    printf("%d", bfs(n, start, end));

    return 0;
}
